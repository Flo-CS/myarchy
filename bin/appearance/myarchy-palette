#!/usr/bin/env python3
"""Palette management utilities for myarchy.

Commands (new names):
  show       - display palette entries for a theme
  normalize  - align colors to a palette by similarity (dry-run by default)
  audit      - report colors outside the palette with suggested replacements
  remap      - positional mapping from one palette to another (dry-run by default)

Compatibility aliases:
  preview -> show
  apply   -> normalize
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from collections import Counter
from pathlib import Path
from typing import Dict, Iterator, List, NoReturn, Optional, Sequence, Tuple


def _base_dir() -> Path:
    env_dir = os.environ.get("MYARCHY_DIR")
    if env_dir:
        return Path(env_dir)
    # Fallback to repository root: bin/appearance/../../
    return Path(__file__).resolve().parents[2]


THEMES_DIR = _base_dir() / "files" / "themes"


def fail(msg: str, code: int = 1) -> NoReturn:
    print(msg, file=sys.stderr)
    raise SystemExit(code)


ColorMatch = Tuple[str, str, str]  # (normalized, raw, relative_file)


HEX_PATTERN = re.compile(r"#(?:[0-9a-fA-F]{6}|[0-9a-fA-F]{8})")
RGBA_PATTERN = re.compile(r"(rgba?\([^)]*\))", re.IGNORECASE)


def normalize_color(color: str) -> str:
    """Lowercase and strip whitespace to create a canonical color token."""
    return re.sub(r"\s+", "", color.strip()).lower()


def parse_rgb(color: str) -> Optional[Tuple[int, int, int]]:
    """Parse a color token into an RGB tuple, ignoring alpha if present."""
    token = normalize_color(color)

    hex_match = re.fullmatch(r"#([0-9a-f]{6})([0-9a-f]{2})?", token)
    if hex_match:
        hex_part = hex_match.group(1)
        return int(hex_part[0:2], 16), int(hex_part[2:4], 16), int(hex_part[4:6], 16)

    rgba_hex_match = re.fullmatch(r"rgba?\(([0-9a-f]{6})([0-9a-f]{2})?\)", token)
    if rgba_hex_match:
        hex_part = rgba_hex_match.group(1)
        return int(hex_part[0:2], 16), int(hex_part[2:4], 16), int(hex_part[4:6], 16)

    rgba_match = re.fullmatch(r"(rgba?)\((\d{1,3}),(\d{1,3}),(\d{1,3})(,[0-9.]+)?\)", token)
    if rgba_match:
        r, g, b = (int(rgba_match.group(i)) for i in range(2, 5))
        if any(channel > 255 for channel in (r, g, b)):
            return None
        return r, g, b

    return None


def rgb_to_hex(rgb: Tuple[int, int, int]) -> str:
    return "#{:02x}{:02x}{:02x}".format(*rgb)


def render_swatch(color: str) -> str:
    """Return a swatch (gum if available, else ANSI truecolor)."""
    rgb = parse_rgb(color)
    if not rgb:
        return ""

    if shutil.which("gum"):
        try:
            out = subprocess.run(
                ["gum", "style", f"--background={rgb_to_hex(rgb)}", "--padding=0 2", " "],
                capture_output=True,
                check=True,
                text=True,
            )
            gum_out = out.stdout.rstrip("\n")
            if gum_out:
                swatch = gum_out + " "
                if swatch.strip():
                    return swatch
        except subprocess.SubprocessError:
            pass

    # ANSI truecolor fallback when interactive; otherwise show a bracketed swatch text.
    r, g, b = rgb
    if sys.stdout.isatty():
        bg = f"\033[48;2;{r};{g};{b}m  \033[0m"
        fg = f"\033[38;2;{r};{g};{b}m██\033[0m"
        swatch = f"{bg}{fg} "
        if swatch.strip():
            return swatch
    return f"[{rgb_to_hex(rgb)}] "


def extract_colors(theme_dir: Path) -> Iterator[ColorMatch]:
    """Yield (normalized, raw, rel_path) for each color occurrence in a theme."""
    for path in theme_dir.rglob("*"):
        if not path.is_file():
            continue
        try:
            data = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue

        rel = str(path.relative_to(theme_dir))

        for match in HEX_PATTERN.finditer(data):
            raw = match.group(0)
            yield normalize_color(raw), raw, rel

        for match in RGBA_PATTERN.finditer(data):
            raw = match.group(1)
            yield normalize_color(raw), raw, rel


def load_palette(palette_file: Path) -> List[str]:
    if not palette_file.is_file():
        fail(f"Palette file not found: {palette_file}")

    colors: List[str] = []
    try:
        lines = palette_file.read_text(encoding="utf-8").splitlines()
    except OSError as exc:
        fail(f"Failed to read palette file {palette_file}: {exc}")

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("//") or stripped.startswith(";") or stripped.startswith("##"):
            continue
        token = stripped.split()[0]
        if not re.fullmatch(r"#[0-9a-fA-F]{6}", token):
            print(f"Skipping invalid palette entry: {line}", file=sys.stderr)
            continue
        colors.append(token.lower())

    if not colors:
        fail(f"Palette is empty at {palette_file}")

    return colors


def format_replacement(src: str, target_hex: str) -> str:
    """Render target_hex using the original format of src (preserve alpha component)."""
    token = normalize_color(src)
    target = normalize_color(target_hex)

    if re.fullmatch(r"#[0-9a-f]{6}", token):
        return target

    if re.fullmatch(r"#[0-9a-f]{8}", token):
        alpha = token[7:9]
        return f"{target}{alpha}"

    rgba_hex = re.fullmatch(r"(rgba?)\(([0-9a-f]{6})([0-9a-f]{2})?\)", token)
    if rgba_hex:
        prefix = rgba_hex.group(1).lower()
        alpha = rgba_hex.group(3) or ""
        rgb_hex = target.lstrip("#")
        if prefix == "rgba" and alpha:
            return f"rgba({rgb_hex}{alpha})"
        return f"rgb({rgb_hex})"

    rgba_dec = re.fullmatch(
        r"(rgba?)\((\d{1,3}),(\d{1,3}),(\d{1,3})(,([0-9.]+))?\)", token, flags=re.IGNORECASE
    )
    if rgba_dec:
        prefix = rgba_dec.group(1).lower()
        alpha = rgba_dec.group(6)
        rgb = parse_rgb(target)
        if not rgb:
            return target
        if prefix == "rgba" and alpha is not None:
            return f"rgba({rgb[0]},{rgb[1]},{rgb[2]},{alpha})"
        return f"rgb({rgb[0]},{rgb[1]},{rgb[2]})"

    return target


def require_theme(theme: str) -> Path:
    if not theme:
        fail("Theme name is required.")
    theme_dir = THEMES_DIR / theme
    if not theme_dir.is_dir():
        fail(f"Theme '{theme}' does not exist.")
    return theme_dir


def palette_path(theme_dir: Path, override: Optional[str]) -> Path:
    return Path(override) if override else theme_dir / "palette.txt"


def command_preview(args: argparse.Namespace) -> None:
    theme_dir = require_theme(args.theme)
    palette_file = palette_path(theme_dir, args.palette)
    palette = load_palette(palette_file)

    print(f"Palette from {palette_file}:")
    for color in palette:
        swatch = render_swatch(color)
        print(f"  {swatch}{color}")


def collect_counts(theme_dir: Path) -> Tuple[Counter[str], Counter[Tuple[str, str]]]:
    total = Counter()
    per_file = Counter()
    for norm, _raw, rel in extract_colors(theme_dir):
        total[norm] += 1
        per_file[(norm, rel)] += 1
    return total, per_file


def compute_nearest_palette(
    palette: Sequence[str], color: str
) -> Tuple[Optional[str], Optional[int]]:
    rgb = parse_rgb(color)
    if not rgb:
        return None, None

    best = None
    best_dist = None
    for entry in palette:
        prgb = parse_rgb(entry)
        if not prgb:
            continue
        dist = (rgb[0] - prgb[0]) ** 2 + (rgb[1] - prgb[1]) ** 2 + (rgb[2] - prgb[2]) ** 2
        if best_dist is None or dist < best_dist:
            best_dist = dist
            best = entry
    return best, best_dist


def replace_in_files(theme_dir: Path, replacements: Dict[str, str]) -> None:
    patterns = {color: re.compile(re.escape(color), flags=re.IGNORECASE) for color in replacements}
    for path in theme_dir.rglob("*"):
        if not path.is_file():
            continue
        try:
            content = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue

        original = content
        for color, target in replacements.items():
            content = patterns[color].sub(target, content)

        if content != original:
            try:
                path.write_text(content, encoding="utf-8")
            except OSError as exc:
                print(f"Failed to write {path}: {exc}", file=sys.stderr)


def describe_files(color: str, file_count: Counter[Tuple[str, str]]) -> str:
    entries = []
    for (c, rel), count in file_count.items():
        if c != color:
            continue
        entries.append(f"{rel}({count})")
    return ", ".join(entries)


def command_apply(args: argparse.Namespace) -> None:
    theme_dir = require_theme(args.theme)
    if args.threshold < 0:
        fail("Threshold must be a non-negative integer.")

    palette_file = palette_path(theme_dir, args.palette)
    palette = load_palette(palette_file)
    palette_set = set(palette)

    total_count, file_count = collect_counts(theme_dir)
    threshold_sq = args.threshold * args.threshold

    replace_map: Dict[str, str] = {}
    formatted_map: Dict[str, str] = {}

    for color, count in total_count.items():
        if color in palette_set:
            continue
        rgb = parse_rgb(color)
        if not rgb:
            continue
        best, best_dist = compute_nearest_palette(palette, color)
        if best is None or best_dist is None or best_dist > threshold_sq:
            continue
        formatted = format_replacement(color, best)
        if formatted == color:
            continue
        replace_map[color] = best
        formatted_map[color] = formatted

    if not replace_map:
        print("No colors within threshold to replace.", file=sys.stderr)
        return

    print(f"Planned replacements (distance <= {args.threshold}):")
    for color, target in replace_map.items():
        rendered = formatted_map[color]
        files_line = describe_files(color, file_count)
        src_sw = render_swatch(color)
        dst_sw = render_swatch(rendered)
        print(
            f"  {src_sw}{color} -> {dst_sw}{rendered} "
            f"(count={total_count[color]}) files: {files_line}"
        )

    if not args.apply:
        print("Dry run. Use --apply to write changes.", file=sys.stderr)
        return

    replacements = {color: formatted_map[color] for color in replace_map}
    replace_in_files(theme_dir, replacements)
    print(f"Applied palette replacements using {palette_file}.")


def command_audit(args: argparse.Namespace) -> None:
    theme_dir = require_theme(args.theme)
    if args.threshold < 0:
        fail("Threshold must be a non-negative integer.")

    palette_file = palette_path(theme_dir, args.palette)
    palette = load_palette(palette_file)
    palette_set = set(palette)
    total_count, file_count = collect_counts(theme_dir)
    threshold_sq = args.threshold * args.threshold

    print(f"Colors not in palette (distance <= {args.threshold} suggests replacement):")
    for color, count in total_count.items():
        if color in palette_set:
            continue
        rgb = parse_rgb(color)
        if not rgb:
            continue

        best, best_dist = compute_nearest_palette(palette, color)
        files_line = describe_files(color, file_count)
        src_sw = render_swatch(color)
        dst_sw = render_swatch(best) if best else ""

        if best is not None and best_dist is not None and best_dist <= threshold_sq:
            rendered = format_replacement(color, best)
            if rendered == color:
                continue
            print(
                f"  {src_sw}{color} -> {dst_sw}{rendered} "
                f"(count={count}) files: {files_line}"
            )
        else:
            print(
                f"  {src_sw}{color} (count={count}) files: {files_line} "
                f"(no close replacement within {args.threshold})"
            )


def command_remap(args: argparse.Namespace) -> None:
    theme_dir = require_theme(args.theme)
    from_palette = Path(args.from_palette) if args.from_palette else theme_dir / "palette.txt"
    to_palette = Path(args.to_palette)

    from_colors = load_palette(from_palette)
    to_colors = load_palette(to_palette)

    if len(from_colors) != len(to_colors):
        fail(
            f"Palette sizes differ (from={len(from_colors)}, to={len(to_colors)}). "
            "Align them before remapping."
        )

    total_count, file_count = collect_counts(theme_dir)

    replace_map: Dict[str, str] = {}
    formatted_map: Dict[str, str] = {}
    for src, dst in zip(from_colors, to_colors):
        if src == dst:
            continue
        replace_map[src] = dst
        formatted_map[src] = format_replacement(src, dst)

    if not replace_map:
        print("No remaps to apply (palettes identical?).", file=sys.stderr)
        return

    print(f"Planned palette remap (positional from -> to):")
    for src, dst in replace_map.items():
        rendered = formatted_map[src]
        files_line = describe_files(src, file_count)
        src_sw = render_swatch(src)
        dst_sw = render_swatch(rendered)
        print(
            f"  {src_sw}{src} -> {dst_sw}{rendered} "
            f"(count={total_count.get(src,0)}) files: {files_line}"
        )

    if not args.apply:
        print("Dry run. Use --apply to write changes.", file=sys.stderr)
        return

    replacements = {color: formatted_map[color] for color in replace_map}
    replace_in_files(theme_dir, replacements)
    print(f"Applied palette remap using {from_palette} -> {to_palette}.")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Palette management utilities for myarchy.",
        usage=(
            "myarchy-palette {show <theme> [--palette <path>]|"
            "normalize <theme> [--threshold <n>] [--palette <path>] [--write]|"
            "audit <theme> [--palette <path>] [--threshold <n>]|"
            "remap <theme> --to <palette> [--from <palette>] [--write]}"
        ),
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    show = subparsers.add_parser("show", help="Show palette entries for a theme")
    show.add_argument("theme")
    show.add_argument("--palette", help="Override palette path")
    show.set_defaults(func=command_preview)

    # Compatibility alias
    preview = subparsers.add_parser("preview", help=argparse.SUPPRESS)
    preview.add_argument("theme")
    preview.add_argument("--palette", help="Override palette path")
    preview.set_defaults(func=command_preview)

    normalize = subparsers.add_parser(
        "normalize", help="Normalize colors toward a palette (dry-run by default)"
    )
    normalize.add_argument("theme")
    normalize.add_argument("--threshold", type=int, default=12, help="RGB distance threshold")
    normalize.add_argument("--palette", help="Override palette path")
    normalize.add_argument("--write", action="store_true", dest="apply", help="Write changes to files")
    normalize.add_argument("--apply", action="store_true", dest="apply", help=argparse.SUPPRESS)
    normalize.set_defaults(func=command_apply)

    # Compatibility alias
    apply = subparsers.add_parser("apply", help=argparse.SUPPRESS)
    apply.add_argument("theme")
    apply.add_argument("--threshold", type=int, default=12, help="RGB distance threshold")
    apply.add_argument("--palette", help="Override palette path")
    apply.add_argument("--apply", action="store_true", help="Write changes to files")
    apply.set_defaults(func=command_apply)

    audit = subparsers.add_parser("audit", help="Report colors outside the palette")
    audit.add_argument("theme")
    audit.add_argument("--palette", help="Override palette path")
    audit.add_argument("--threshold", type=int, default=12, help="RGB distance threshold")
    audit.set_defaults(func=command_audit)

    remap = subparsers.add_parser("remap", help="Positional remap between palettes (dry-run by default)")
    remap.add_argument("theme")
    remap.add_argument("--from", dest="from_palette", help="Source palette (defaults to theme palette)")
    remap.add_argument("--to", dest="to_palette", required=True, help="Destination palette path")
    remap.add_argument("--write", action="store_true", dest="apply", help="Write changes to files")
    remap.add_argument("--apply", action="store_true", dest="apply", help=argparse.SUPPRESS)
    remap.set_defaults(func=command_remap)

    return parser


def main(argv: Optional[Sequence[str]] = None) -> None:
    parser = build_parser()
    args = parser.parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    main()
