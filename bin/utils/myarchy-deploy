#!/usr/bin/env bash

deploy_applications() {
	$MYARCHY_DIR/files/deploy-applications
}

deploy_config() {
	$MYARCHY_DIR/files/deploy-config
	myarchy-refresh all
}

deploy_all() {
	deploy_config
	deploy_applications
}

command="$1"

case $command in
all)
	deploy_all
	;;
config)
	deploy_config
	;;
applications)
	deploy_applications
	;;
*)
	echo "Usage: myarchy-deploy {all|config|applications}"
	exit 1
	;;
esac
