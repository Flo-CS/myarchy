#!/usr/bin/env bash

refresh_all() {
	# Alacritty
	touch ~/.config/alacritty/alacritty.toml # Trigger reload

	# Bat
	bat cache --build

	# Waybar
	pkill -x waybar && setsid uwsm app -- waybar &

	# Mako
	makoctl reload &

	# Hyprland
	hyprctl reload &
}

case "$1" in
all)
	refresh_all
	;;
*)
	echo "Usage: $0 all"
	exit 1
	;;
esac
