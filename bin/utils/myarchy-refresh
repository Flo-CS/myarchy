#!/usr/bin/env bash

refresh_terminal() {
	# Alacritty
	touch ~/.config/alacritty/alacritty.toml # Trigger reload

	# Starship template
	myarchy-lib render-template ~/.config/starship.toml.j2 ~/.config/starship.toml

	# Bat
	bat cache --build
}

refresh_desktop() {
	# Waybar
	pkill -x waybar && setsid uwsm app -- waybar &

	# Mako
	myarchy-lib render-template ~/.config/mako/config.j2 ~/.config/mako/config
	makoctl reload &

	# Hyprland
	hyprctl reload &
}

refresh_all() {
	refresh_desktop
	refresh_terminal
}

command="$1"

case $command in
"desktop")
	refresh_desktop
	;;
"terminal")
	refresh_terminal
	;;
"all")
	refresh_all
	;;
*)
	echo "Usage: $0 {desktop|terminal|all}"
	exit 1
	;;
esac
