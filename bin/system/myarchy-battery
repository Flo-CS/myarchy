#!/usr/bin/env bash

get_battery_percentage() {
  upower -i "$(upower -e | grep 'BAT')" |
    awk -F: '/percentage/ {
      gsub(/[%[:space:]]/, "", $2);
      val=$2;
      printf("%d\n", (val+0.5))
      exit
    }'
}

get_battery_state() {
  upower -i $(upower -e | grep 'BAT') | grep -E "state" | awk '{print $2}'
}

case "$1" in
percentage)
  get_battery_percentage
  ;;
state)
  get_battery_state
  ;;
*)
  echo "Usage: $0 {percentage|state}"
  exit 1
  ;;
esac
