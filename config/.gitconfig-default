[pull]
	rebase = true
[push]
	autoSetupRemote = true
[diff]
	algorithm = histogram
	colorMoved = false
	mnemonicPrefix = true
	tool = nvimdiff
	guitool = nvimdiff
[commit]
	verbose = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = -version:refname
[rerere]
	enabled = true
	autoupdate = true
[init]
	defaultBranch = main
[core]
	editor = nvim
	pager = delta
[merge]
	tool = nvimdiff
	conflictStyle = zdiff3
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	hunk-header-style = omit # Git can't infer hunk header correctly for some languages and it's more confusing than useful, so we remove it entirely
	line-numbers = true
 
