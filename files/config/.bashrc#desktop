#!/usr/bin/env bash

source ~/.config/rc/functions.sh
source ~/.config/rc/aliases.sh
source ~/.config/rc/theming.sh
source ~/.config/rc/settings.sh

if command -v starship &>/dev/null; then
	eval "$(starship init bash)"
fi

if command -v zoxide &>/dev/null; then
	eval "$(zoxide init bash)"
fi

[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh

. "$HOME/.cargo/env"

. /usr/share/nvm/init-nvm.sh

export DEV_TOOLS_PATH="$HOME/dev/tools"

export PATH="$DEV_TOOLS_PATH/flutter/bin:$PATH"

export ANDROID_AVD_HOME="$HOME/.config/.android/avd"
export ANDROID_SDK_HOME="$DEV_TOOLS_PATH/android/sdk"

eval "$(direnv hook bash)"
